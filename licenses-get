#!/usr/bin/env bash

__data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/licenses"
__license_id="$1"

if [[ -z "$__license_id" ]]; then
    printf 'usage: %s <license-id>\n' "${0##*/}" >&2
    exit 1
fi

__license_path="${__data_dir}/${__license_id}"

if [[ ! -f "$__license_path" ]]; then
    printf 'license not found: %s (run licenses-update to sync)\n' "$__license_id" >&2
    exit 1
fi

cp "$__license_path" LICENSE || {
    printf 'failed to copy license file\n' >&2
    exit 1
}

printf 'copied %s to LICENSE\n' "$__license_id"
